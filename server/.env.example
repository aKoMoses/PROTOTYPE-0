# Port the server listens on
PORT=2567

# Supabase JWT secret (Settings > API > JWT Secret in your Supabase project)
# If left empty, tokens are decoded but NOT verified (dev only).
SUPABASE_JWT_SECRET=

# Supabase project URL and service role key used by the server to persist match results.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Allowed client origin for CORS (use * to allow all in dev)
CLIENT_ORIGIN=http://localhost:5173
