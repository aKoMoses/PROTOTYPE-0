{
  "name": "prototype-0-server",
  "version": "1.0.0",
  "description": "Colyseus authoritative game server for PROTOTYPE-0",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "start": "node dist/server/src/index.js"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.8",
    "@supabase/supabase-js": "^2.57.4",
    "colyseus": "^0.17.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
